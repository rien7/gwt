{
  "name": "@rien7/gwt",
  "type": "module",
  "version": "1.1.0",
  "description": "A CLI for managing Git worktrees with a bare-repo workspace layout",
  "license": "MIT",
  "author": "rien7",
  "homepage": "https://github.com/rien7/gwt#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rien7/gwt.git"
  },
